# Meridian — Environment Configuration
# Copy this file to .env and customize

# Solana cluster (devnet, mainnet-beta, localnet)
SOLANA_CLUSTER=devnet

# RPC URL (optional, defaults to public devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Admin wallet path (defaults to Solana CLI default)
ANCHOR_WALLET=~/.config/solana/id.json

# Anchor provider URL (same as RPC URL)
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
